<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      Local-feed override for in-progress MonorailCss.Discovery + Pennington packages.
      The Pennington 0.1.0-local.0 builds emitted here transitively pull MonorailCss
      0.0.99-local.0 + MonorailCss.Discovery 0.0.99-local.0 from the same feed.
    -->
    <add key="monorail-local" value="B:\monorail-local-feed" />
  </packageSources>
</configuration>
