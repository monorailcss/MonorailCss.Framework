@inherits LayoutComponentBase
@inject ContentResolver ContentResolver
@inject NavigationBuilder NavigationBuilder
@inject NavigationManager NavigationManager

<div class="min-h-screen font-sans text-base-50 bg-base-950 [background-image:linear-gradient(rgba(232,148,95,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(232,148,95,0.025)_1px,transparent_1px)] [background-size:56px_56px] [background-attachment:fixed]">

    @* ─────────────────  Top nav  ───────────────── *@
    <header class="sticky top-0 z-50 max-w-[1400px] mx-auto flex items-center justify-between gap-4 px-6 lg:px-8 py-3.5 border-b border-base-800 bg-base-950/75 backdrop-blur-md supports-[backdrop-filter]:bg-base-950/60">
        <div class="flex items-center gap-3">
            <button id="sidebar-toggle"
                    class="lg:hidden p-2 rounded-md text-base-100 hover:bg-base-900 transition-colors"
                    aria-label="Toggle sidebar">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>

            <a href="/" class="flex items-center">
                <span class="font-display text-lg italic font-medium tracking-tight text-accent-500">
                    Monorail<span class="not-italic font-normal text-base-50">Css</span>
                </span>
            </a>
        </div>

        <nav class="hidden md:flex items-center gap-1 text-[13px] text-base-100">
            <a href="/" class="px-3 py-1.5 rounded-md bg-base-900 text-base-50 transition-colors">Documentation</a>
            <a href="https://github.com/monorailcss/MonorailCss.Framework" target="_blank" rel="noopener noreferrer" class="px-3 py-1.5 rounded-md hover:text-accent-500 transition-colors">GitHub ↗</a>
        </nav>

        <div class="flex items-center gap-2">
            <div class="hidden sm:flex items-center gap-2 px-3 py-[7px] rounded-lg bg-base-900 border border-base-800 text-base-500 text-[13px] min-w-[200px] lg:min-w-[240px]">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
                Search docs
                <span class="ml-auto font-mono text-[11px] text-base-500 border border-base-800 px-1.5 py-px rounded">⌘K</span>
            </div>

            <button id="mobile-menu-button"
                    class="md:hidden p-2 rounded-md text-base-100 hover:bg-base-900 transition-colors"
                    aria-label="Toggle menu">
                <svg viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
                    <path d="M8 2a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM8 6.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM9.5 12.5a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0Z"></path>
                </svg>
            </button>
        </div>

        @* Mobile nav *@
        <nav id="mobile-menu" data-expanded="false"
             class="md:hidden data-[expanded=false]:hidden absolute inset-x-0 top-full bg-base-950 border-b border-base-800">
            <div class="px-2 py-3 space-y-1">
                <a href="/" class="block px-3 py-2 rounded-md text-sm font-medium bg-base-900 text-base-50 transition-colors">Documentation</a>
                <a href="https://github.com/monorailcss/MonorailCss.Framework" target="_blank" rel="noopener noreferrer" class="block px-3 py-2 rounded-md text-sm font-medium text-base-100 hover:text-accent-500 hover:bg-base-900 transition-colors">GitHub ↗</a>
            </div>
        </nav>
    </header>

    @* ─────────────────  3-column layout  ───────────────── *@
    <div class="max-w-[1400px] mx-auto grid lg:grid-cols-[280px_1fr]">

        @* Sidebar *@
        <aside class="hidden lg:block sticky top-16 self-start max-h-[calc(100vh-4rem)] overflow-y-auto scrollbar-thin scrollbar-thumb-base-700 scrollbar-track-base-950 scrollbar-color border-r border-base-800 py-8 pr-4 pl-8">
            @if (_toc is not null)
            {
                <TocSidebar Items="_toc" />
            }
        </aside>

        @* Mobile sidebar overlay *@
        <div id="sidebar-overlay" class="lg:hidden fixed inset-0 z-40 hidden bg-base-950/60 backdrop-blur">
            <div id="sidebar-panel" class="fixed inset-y-0 top-16 left-0 w-80 bg-base-950 border-r border-base-800 shadow-xl overflow-y-auto scrollbar-thin scrollbar-thumb-base-700 scrollbar-track-base-950 scrollbar-color">
                <div class="p-4">
                    <button id="sidebar-close" class="mb-4 p-2 rounded-md text-base-100 hover:bg-base-900 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                    @if (_toc is not null)
                    {
                        <TocSidebar Items="_toc" />
                    }
                </div>
            </div>
        </div>

        @* Main content *@
        <main class="min-w-0 px-6 lg:px-14 py-10 pb-20">
            @Body
        </main>
    </div>
</div>


@code{
    private ImmutableList<NavigationTreeItem>? _toc;

    protected override async Task OnInitializedAsync()
    {
        var currentPath = NavigationManager.ToAbsoluteUri(NavigationManager.Uri).AbsolutePath;
        var tocItems = await ContentResolver.GetTocItemsAsync(string.Empty);
        var currentRoute = ContentRouteFactory.FromUrl(new UrlPath(currentPath), string.Empty);
        _toc = NavigationBuilder.BuildTree(tocItems, currentRoute, string.Empty);
        await base.OnInitializedAsync();
    }
}
