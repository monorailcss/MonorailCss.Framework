@inherits LayoutComponentBase
@inject IEnumerable<IContentService> ContentServices
@inject NavigationBuilder NavigationBuilder
@inject NavigationManager NavigationManager

<div class="min-h-screen font-sans text-base-950 dark:text-base-50 bg-base-50 dark:bg-base-950 [background-image:linear-gradient(rgba(232,148,95,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(232,148,95,0.025)_1px,transparent_1px)] [background-size:56px_56px] [background-attachment:fixed]">

    @* ─────────────────  Top nav  ───────────────── *@
    <SiteHeader />

    @* ─────────────────  3-column layout  ───────────────── *@
    <div class="max-w-7xl mx-auto grid lg:grid-cols-[280px_1fr]">

        @* Sidebar — data-spa-region="sidebar" lets spa-engine swap the
           server-rendered active state on every nav, so the TOC always
           reflects the current page without client-side re-syncing. *@
        <aside data-spa-region="sidebar"
               class="hidden lg:block sticky top-16 self-start max-h-[calc(100vh-4rem)] overflow-y-auto scrollbar-thin scrollbar-thumb-base-300 dark:scrollbar-thumb-base-700 scrollbar-track-base-50 dark:scrollbar-track-base-950 scrollbar-color border-r border-base-200 dark:border-base-800 py-8 pr-4 pl-8">
            @if (_toc is not null)
            {
                <TocSidebar Items="_toc" />
            }
        </aside>

        @* Mobile sidebar overlay. The sidebar-mobile region wraps just the
           TocSidebar so the close button stays put across SPA nav. *@
        <div id="sidebar-overlay" class="lg:hidden fixed inset-0 z-40 hidden bg-base-50/60 dark:bg-base-950/60 backdrop-blur">
            <div id="sidebar-panel" class="fixed inset-y-0 top-16 left-0 w-80 bg-base-50 dark:bg-base-950 border-r border-base-200 dark:border-base-800 shadow-xl overflow-y-auto scrollbar-thin scrollbar-thumb-base-300 dark:scrollbar-thumb-base-700 scrollbar-track-base-50 dark:scrollbar-track-base-950 scrollbar-color">
                <div class="p-4">
                    <button id="sidebar-close" class="mb-4 p-2 rounded-md text-base-900 dark:text-base-100 hover:bg-base-100 dark:hover:bg-base-900 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                    <div data-spa-region="sidebar-mobile">
                        @if (_toc is not null)
                        {
                            <TocSidebar Items="_toc" />
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Main content *@
        <main id="main-content" class="min-w-0 pl-6 lg:pl-14 py-10 pb-20">
            @Body
        </main>
    </div>
</div>


@code{
    private ImmutableList<NavigationTreeItem>? _toc;

    protected override async Task OnInitializedAsync()
    {
        var currentPath = NavigationManager.ToAbsoluteUri(NavigationManager.Uri).AbsolutePath;

        // Aggregate the TOC entries every registered content service contributes — the
        // markdown docs source plus UtilityContentService. This is the bare-host
        // equivalent of the old DocSiteContentResolver.GetTocItemsAsync.
        var perService = await Task.WhenAll(ContentServices.Select(s => s.GetContentTocEntriesAsync()));
        var tocItems = perService.SelectMany(items => items).ToList();

        // BuildTreeAsync takes the current URL path directly (UrlPath?) rather than a ContentRoute.
        _toc = await NavigationBuilder.BuildTreeAsync(tocItems, new UrlPath(currentPath), string.Empty);
        await base.OnInitializedAsync();
    }
}
