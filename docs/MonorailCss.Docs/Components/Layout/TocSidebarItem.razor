@if (Item is not null)
{
    <li>
        <a href="@Item.Route.CanonicalPath.Value"
           class="block px-3 py-1.5 rounded-md border-l-2 transition-colors @(Item.IsSelected
               ? "border-orange-500 bg-orange-500/[0.06] text-orange-500"
               : "border-transparent text-warm-100 hover:bg-orange-500/[0.04] hover:text-orange-500")">
            @Item.Title
        </a>
        @if (Item.Children is { Count: > 0 })
        {
            <ul class="ml-3 mt-px space-y-px border-l border-warm-800 pl-3">
                @foreach (var child in Item.Children)
                {
                    <TocSidebarItem Item="child" />
                }
            </ul>
        }
    </li>
}

@code {
    [Parameter] public NavigationTreeItem? Item { get; set; }
}
