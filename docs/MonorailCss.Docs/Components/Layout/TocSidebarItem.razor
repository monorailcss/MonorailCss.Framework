@if (Item is not null)
{
    <li>
        <a href="@Item.Route.CanonicalPath.Value"
           class="block px-2 py-1 rounded @(Item.IsSelected
               ? "bg-primary-100 dark:bg-primary-900/40 text-primary-900 dark:text-primary-100 font-medium"
               : "text-base-700 dark:text-base-300 hover:text-base-900 dark:hover:text-base-100 hover:bg-base-100 dark:hover:bg-base-800") transition-colors">
            @Item.Title
        </a>
        @if (Item.Children is { Count: > 0 })
        {
            <ul class="ml-3 mt-1 space-y-1 border-l border-base-200 dark:border-base-800 pl-3">
                @foreach (var child in Item.Children)
                {
                    <TocSidebarItem Item="child" />
                }
            </ul>
        }
    </li>
}

@code {
    [Parameter] public NavigationTreeItem? Item { get; set; }
}
