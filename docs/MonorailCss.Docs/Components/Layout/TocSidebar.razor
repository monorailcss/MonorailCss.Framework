@if (Items is { Count: > 0 })
{
    <nav class="text-sm space-y-6">
        @foreach (var sectionGroup in Items.GroupBy(i => i.Section ?? string.Empty))
        {
            @if (!string.IsNullOrWhiteSpace(sectionGroup.Key))
            {
                <div>
                    <div class="text-xs font-semibold text-base-500 dark:text-base-400 uppercase tracking-wider mb-2 px-2">
                        @sectionGroup.Key
                    </div>
                    <ul class="space-y-1">
                        @foreach (var item in sectionGroup)
                        {
                            <TocSidebarItem Item="item" />
                        }
                    </ul>
                </div>
            }
            else
            {
                <ul class="space-y-1">
                    @foreach (var item in sectionGroup)
                    {
                        <TocSidebarItem Item="item" />
                    }
                </ul>
            }
        }
    </nav>
}

@code {
    [Parameter] public ImmutableList<NavigationTreeItem>? Items { get; set; }
}
