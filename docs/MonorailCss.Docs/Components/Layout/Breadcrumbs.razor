@if (Items != null && Items.Any())
{
    <nav class="flex items-center font-mono text-xs text-base-700 dark:text-base-300 tracking-[0.02em] mb-6">
        @foreach (var (breadcrumb, index) in Items.Select((b, i) => (b, i)))
        {
            @if (index > 0)
            {
                <span class="mx-2 text-base-500 dark:text-base-500">/</span>
            }

            @if (breadcrumb.IsCurrent)
            {
                <span class="text-base-950 dark:text-base-50">@breadcrumb.Title</span>
            }
            else if (string.IsNullOrEmpty(breadcrumb.Url))
            {
                <span>@breadcrumb.Title</span>
            }
            else
            {
                <a href="@breadcrumb.Url" class="hover:text-accent-500 transition-colors">@breadcrumb.Title</a>
            }
        }
    </nav>
}

@code {
    [Parameter]
    public List<BreadcrumbItem>? Items { get; set; }

    public class BreadcrumbItem
    {
        public string Title { get; set; } = string.Empty;
        public string? Url { get; set; }
        public bool IsCurrent { get; set; }
    }
}
