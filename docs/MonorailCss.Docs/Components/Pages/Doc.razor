@page "/{*slug}"
@inject ContentResolver ContentResolver
@inject MonorailCss.Docs.Services.UtilityContentService UtilityService
@layout MainLayout

<PageTitle>@_pageTitle</PageTitle>

@if (string.IsNullOrEmpty(Slug))
{
    <p>Not found</p>
}
else
{
    <ContentIsland Url="@($"/{Slug.TrimEnd('/')}")" />
}

@code {
    [Parameter] public string? Slug { get; set; }

    private string _pageTitle = "MonorailCss";

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Slug))
        {
            _pageTitle = "Not found - MonorailCss";
            return;
        }

        var url = $"/{Slug.TrimEnd('/')}";
        var markdown = await ContentResolver.GetContentByUrlAsync(url);
        if (markdown is not null)
        {
            _pageTitle = $"{markdown.Title} - MonorailCss";
            return;
        }

        var segments = Slug.Trim('/').Split('/');
        if (segments.Length == 2)
        {
            var utilities = await UtilityService.GetUtilitiesForPropertyAsync(segments[0], segments[1]);
            if (utilities is not null)
            {
                _pageTitle = $"{utilities.DisplayName} - MonorailCss";
                return;
            }
        }

        _pageTitle = "Not found - MonorailCss";
    }
}
