@page "/api-reference"
@using System.Text.RegularExpressions
@using MonorailCss.Docs.Services
@inject ApiReferenceService Api
@layout MainLayout

<PageTitle>API Reference - MonorailCss</PageTitle>

<div data-spa-region="content" data-spa-loading="skeleton">
    <Breadcrumbs Items="@_breadcrumbs" />

    <div class="space-y-12">
        <header class="space-y-4">
            <h1 class="text-4xl font-bold text-base-900 dark:text-primary-50">API Reference</h1>
            <p class="text-base-600 dark:text-base-400 text-lg lg:text-xl max-w-2xl">
                The customer-facing surface of <code class="font-mono text-tertiary-one-900 dark:text-tertiary-one-400">MonorailCss</code>.
                Public types you'll touch when configuring or extending the engine.
            </p>
            <div class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-xs text-base-500 dark:text-base-400 pt-2">
                <span><b class="text-base-900 dark:text-primary-50 font-medium">@Api.Types.Count</b> types</span>
                <span><b class="text-base-900 dark:text-primary-50 font-medium">@MemberCount()</b> members</span>
                <span>net10.0</span>
                <span class="ml-auto flex flex-wrap gap-x-3 gap-y-1">
                    @foreach (var t in Api.Types)
                    {
                        <a href="#@t.Id" class="text-tertiary-one-900 dark:text-tertiary-one-400 hover:underline">@t.Name</a>
                    }
                </span>
            </div>
        </header>

        @foreach (var type in Api.Types)
        {
            <section id="@type.Id" class="scroll-mt-20 space-y-4">
                <div class="flex items-baseline flex-wrap gap-x-3 gap-y-1 pb-3 border-b border-base-200 dark:border-base-800">
                    <span class="font-mono text-[10px] uppercase tracking-[0.12em] px-2 py-0.5 rounded border @KindClasses(type.Kind)">
                        @type.KindLabel
                    </span>
                    <span class="font-mono text-2xl font-medium text-base-900 dark:text-primary-50 tracking-tight">
                        <span class="text-base-400 dark:text-base-500 text-base font-normal">@type.Namespace.</span>@type.Name
                    </span>
                    <a href="#@type.Id" class="ml-auto font-mono text-xs text-base-400 dark:text-base-500 hover:text-tertiary-one-900 dark:hover:text-tertiary-one-400" aria-label="Anchor">#</a>
                </div>

                @if (!string.IsNullOrEmpty(type.Summary))
                {
                    <p class="text-base-600 dark:text-base-400 text-[15px] leading-relaxed max-w-3xl">
                        @((MarkupString)RenderInlineCode(type.Summary))
                    </p>
                }

                @if (type.Properties.Count > 0)
                {
                    <div class="pt-2">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="text-sm font-medium text-base-900 dark:text-primary-50">Properties</span>
                            <span class="font-mono text-[11px] text-base-500 dark:text-base-400 px-1.5 py-0.5 bg-base-100 dark:bg-base-800 rounded">@type.Properties.Count</span>
                            <span class="flex-1 h-px bg-gradient-to-r from-base-200 dark:from-base-800 to-transparent"></span>
                        </div>
                        <table class="w-full font-mono text-[13px] border-collapse">
                            <tbody>
                                @foreach (var p in type.Properties)
                                {
                                    <tr class="border-b border-base-100 dark:border-base-800/60 last:border-0 hover:bg-base-50/50 dark:hover:bg-base-900/40">
                                        <td class="py-2 pr-4 align-top whitespace-nowrap">
                                            <span class="text-base-900 dark:text-primary-50 font-medium">@p.Name</span>
                                            @foreach (var tag in p.Tags)
                                            {
                                                <span class="@TagClasses(tag) ml-1.5 inline-block font-sans text-[10px] font-medium uppercase tracking-wide px-1.5 py-px rounded border align-[2px]">@tag</span>
                                            }
                                        </td>
                                        <td class="py-2 pr-4 align-top whitespace-nowrap text-[12.5px]">
                                            @((MarkupString)RenderType(p.Type))
                                        </td>
                                        <td class="py-2 align-top font-sans text-[13px] text-base-600 dark:text-base-400 leading-snug">
                                            @((MarkupString)RenderInlineCode(p.Summary))
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @{
                    var ctors = type.Methods.Where(m => m.IsConstructor).ToList();
                    var methods = type.Methods.Where(m => !m.IsConstructor).ToList();
                }

                @if (ctors.Count > 0)
                {
                    <div class="pt-2">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="text-sm font-medium text-base-900 dark:text-primary-50">Constructors</span>
                            <span class="font-mono text-[11px] text-base-500 dark:text-base-400 px-1.5 py-0.5 bg-base-100 dark:bg-base-800 rounded">@ctors.Count</span>
                            <span class="flex-1 h-px bg-gradient-to-r from-base-200 dark:from-base-800 to-transparent"></span>
                        </div>
                        <table class="w-full font-mono text-[13px] border-collapse">
                            <tbody>
                                @foreach (var m in ctors)
                                {
                                    <tr class="border-b border-base-100 dark:border-base-800/60 last:border-0 hover:bg-base-50/50 dark:hover:bg-base-900/40">
                                        <td class="py-2 pr-4 align-top">
                                            <span class="text-base-900 dark:text-primary-50 font-medium">@m.Name</span><span class="text-base-400 dark:text-base-500">(@((MarkupString)RenderParams(m.Params)))</span>
                                        </td>
                                        <td class="py-2 align-top font-sans text-[13px] text-base-600 dark:text-base-400 leading-snug">
                                            @((MarkupString)RenderInlineCode(m.Summary))
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (methods.Count > 0)
                {
                    <div class="pt-2">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="text-sm font-medium text-base-900 dark:text-primary-50">Methods</span>
                            <span class="font-mono text-[11px] text-base-500 dark:text-base-400 px-1.5 py-0.5 bg-base-100 dark:bg-base-800 rounded">@methods.Count</span>
                            <span class="flex-1 h-px bg-gradient-to-r from-base-200 dark:from-base-800 to-transparent"></span>
                        </div>
                        <table class="w-full font-mono text-[13px] border-collapse">
                            <tbody>
                                @foreach (var m in methods)
                                {
                                    <tr class="border-b border-base-100 dark:border-base-800/60 last:border-0 hover:bg-base-50/50 dark:hover:bg-base-900/40">
                                        <td class="py-2 pr-4 align-top">
                                            <span class="text-base-900 dark:text-primary-50 font-medium">@m.Name</span><span class="text-base-400 dark:text-base-500">(@((MarkupString)RenderParams(m.Params)))</span>
                                            @foreach (var tag in m.Tags)
                                            {
                                                <span class="@TagClasses(tag) ml-1.5 inline-block font-sans text-[10px] font-medium uppercase tracking-wide px-1.5 py-px rounded border align-[2px]">@tag</span>
                                            }
                                        </td>
                                        <td class="py-2 pr-4 align-top whitespace-nowrap text-[12.5px]">
                                            @if (!string.IsNullOrEmpty(m.ReturnType))
                                            {
                                                <span class="text-base-400 dark:text-base-500">→ </span>@((MarkupString)RenderType(m.ReturnType))
                                            }
                                        </td>
                                        <td class="py-2 align-top font-sans text-[13px] text-base-600 dark:text-base-400 leading-snug">
                                            @((MarkupString)RenderInlineCode(m.Summary))
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (type.EnumValues.Count > 0)
                {
                    <div class="pt-2">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="text-sm font-medium text-base-900 dark:text-primary-50">Values</span>
                            <span class="font-mono text-[11px] text-base-500 dark:text-base-400 px-1.5 py-0.5 bg-base-100 dark:bg-base-800 rounded">@type.EnumValues.Count</span>
                            <span class="flex-1 h-px bg-gradient-to-r from-base-200 dark:from-base-800 to-transparent"></span>
                        </div>
                        <table class="w-full font-mono text-[13px] border-collapse">
                            <tbody>
                                @foreach (var v in type.EnumValues)
                                {
                                    <tr class="border-b border-base-100 dark:border-base-800/60 last:border-0 hover:bg-base-50/50 dark:hover:bg-base-900/40">
                                        <td class="py-2 pr-4 align-top whitespace-nowrap">
                                            <span class="text-base-900 dark:text-primary-50 font-medium">@v.Name</span>
                                        </td>
                                        <td class="py-2 pr-4 align-top whitespace-nowrap text-[12.5px] text-base-500 dark:text-base-400">
                                            @if (!string.IsNullOrEmpty(v.Value))
                                            {
                                                <text>= @v.Value</text>
                                            }
                                        </td>
                                        <td class="py-2 align-top font-sans text-[13px] text-base-600 dark:text-base-400 leading-snug">
                                            @((MarkupString)RenderInlineCode(v.Summary))
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="flex items-center gap-3 pt-2 font-mono text-[11px] text-base-500 dark:text-base-400">
                    <span class="text-base-400 dark:text-base-500">SOURCE</span>
                    <a href="https://github.com/monorailcss/MonorailCss.Framework/blob/main/@type.SourcePath"
                       target="_blank" rel="noopener noreferrer"
                       class="text-base-700 dark:text-base-300 hover:text-tertiary-one-900 dark:hover:text-tertiary-one-400 hover:underline">
                        @type.SourcePath ↗
                    </a>
                </div>
            </section>
        }
    </div>
</div>

@code {
    private static readonly HashSet<string> Primitives = new(StringComparer.Ordinal)
    {
        "string", "int", "long", "short", "byte", "bool", "float", "double", "decimal",
        "object", "void", "char", "Task", "ValueTask",
        "List", "IList", "IEnumerable", "IReadOnlyList", "IReadOnlyDictionary",
        "Dictionary", "Action", "Func", "Predicate", "Span",
        "ImmutableList", "ImmutableHashSet", "ImmutableDictionary", "ImmutableArray",
        "params",
    };

    private static readonly Regex TokenSplitter = new(@"([A-Za-z_]\w*|[<>,?\[\]\s\.]+|[^A-Za-z_<>,?\[\]\s\.]+)", RegexOptions.Compiled);
    private static readonly Regex CodeBackticks = new("`([^`]+)`", RegexOptions.Compiled);

    private List<Breadcrumbs.BreadcrumbItem> _breadcrumbs = [];

    protected override void OnInitialized()
    {
        _breadcrumbs =
        [
            new() { Title = "Home", Url = "/" },
            new() { Title = "Reference", Url = string.Empty },
            new() { Title = "API Reference", IsCurrent = true },
        ];
    }

    private int MemberCount() =>
        Api.Types.Sum(t => t.Properties.Count + t.Methods.Count + t.EnumValues.Count);

    private static string KindClasses(string kind) => kind switch
    {
        "C" => "text-accent-700 dark:text-accent-400 border-accent-200 dark:border-accent-800/60 bg-accent-50/50 dark:bg-accent-900/20",
        "I" => "text-tertiary-one-700 dark:text-tertiary-one-400 border-tertiary-one-200 dark:border-tertiary-one-800/60 bg-tertiary-one-50/50 dark:bg-tertiary-one-900/20",
        "E" => "text-primary-700 dark:text-primary-400 border-primary-200 dark:border-primary-800/60 bg-primary-50/50 dark:bg-primary-900/20",
        _ => "text-base-700 dark:text-base-300 border-base-200 dark:border-base-700 bg-base-50 dark:bg-base-900",
    };

    private static string TagClasses(string tag) => tag switch
    {
        "static" => "text-primary-700 dark:text-primary-400 border-primary-200 dark:border-primary-800/60 bg-transparent",
        "async" => "text-accent-700 dark:text-accent-400 border-accent-200 dark:border-accent-800/60 bg-transparent",
        "virtual" => "text-tertiary-one-700 dark:text-tertiary-one-400 border-tertiary-one-200 dark:border-tertiary-one-800/60 bg-transparent",
        _ => "text-base-500 dark:text-base-400 border-base-200 dark:border-base-700 bg-transparent",
    };

    private string RenderType(string raw)
    {
        if (string.IsNullOrEmpty(raw))
        {
            return string.Empty;
        }

        var sb = new System.Text.StringBuilder();
        foreach (Match match in TokenSplitter.Matches(raw))
        {
            var token = match.Value;
            if (Regex.IsMatch(token, @"^[A-Za-z_]\w*$"))
            {
                if (Primitives.Contains(token))
                {
                    sb.Append("<span class=\"text-base-600 dark:text-base-400\">").Append(System.Net.WebUtility.HtmlEncode(token)).Append("</span>");
                }
                else
                {
                    sb.Append("<span class=\"text-tertiary-one-900 dark:text-tertiary-one-400\">").Append(System.Net.WebUtility.HtmlEncode(token)).Append("</span>");
                }
            }
            else
            {
                sb.Append("<span class=\"text-base-400 dark:text-base-500\">").Append(System.Net.WebUtility.HtmlEncode(token)).Append("</span>");
            }
        }

        return sb.ToString();
    }

    private string RenderParams(System.Collections.Immutable.ImmutableList<ApiParamDoc> ps)
    {
        if (ps.Count == 0)
        {
            return string.Empty;
        }

        var parts = ps.Select(p =>
            "<span class=\"text-base-700 dark:text-base-300\">" + System.Net.WebUtility.HtmlEncode(p.Name) + "</span>" +
            "<span class=\"text-base-400 dark:text-base-500\">: </span>" +
            RenderType(p.Type));

        return string.Join("<span class=\"text-base-400 dark:text-base-500\">, </span>", parts);
    }

    private static string RenderInlineCode(string text)
    {
        if (string.IsNullOrEmpty(text))
        {
            return string.Empty;
        }

        var encoded = System.Net.WebUtility.HtmlEncode(text);
        return CodeBackticks.Replace(encoded, m =>
            "<code class=\"font-mono text-[12.5px] text-tertiary-one-900 dark:text-tertiary-one-400\">" + m.Groups[1].Value + "</code>");
    }
}
