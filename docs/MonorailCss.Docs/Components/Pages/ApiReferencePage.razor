@page "/api-reference"
@using Pennington.ApiMetadata
@inject IApiMetadataProvider Api
@inject IXmlDocHtmlRenderer DocRenderer
@layout MainLayout

<PageTitle>API Reference - MonorailCss</PageTitle>

<div data-spa-region="content" data-spa-loading="skeleton">
    <Breadcrumbs Items="@_breadcrumbs" />

    <div class="space-y-12">
        <header class="space-y-4">
            <h1 class="text-4xl font-bold text-base-900 dark:text-primary-50">API Reference</h1>
            <p class="text-base-600 dark:text-base-400 text-lg lg:text-xl max-w-2xl">
                The customer-facing surface of <code class="font-mono text-tertiary-one-900 dark:text-tertiary-one-400">MonorailCss</code>.
                Public types you'll touch when configuring or extending the engine.
            </p>
            <div class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-xs text-base-500 dark:text-base-400 pt-2">
                <span><b class="text-base-900 dark:text-primary-50 font-medium">@_types.Count</b> types</span>
                <span><b class="text-base-900 dark:text-primary-50 font-medium">@_types.Sum(t => t.MemberCount)</b> members</span>
                <span>net10.0</span>
                <span class="ml-auto flex flex-wrap gap-x-3 gap-y-1">
                    @foreach (var t in _types)
                    {
                        <a href="#@t.Id" class="text-tertiary-one-900 dark:text-tertiary-one-400 hover:underline">@t.Name</a>
                    }
                </span>
            </div>
        </header>

        @foreach (var type in _types)
        {
            <section id="@type.Id" class="scroll-mt-20 space-y-4">
                <div class="flex items-baseline flex-wrap gap-x-3 gap-y-1 pb-3 border-b border-base-200 dark:border-base-800">
                    <span class="font-mono text-[10px] uppercase tracking-[0.12em] px-2 py-0.5 rounded border @KindClasses(type.KindCode)">
                        @type.KindLabel
                    </span>
                    <span class="font-mono text-2xl font-medium text-base-900 dark:text-primary-50 tracking-tight">
                        <span class="text-base-400 dark:text-base-500 text-base font-normal">@type.Namespace.</span>@type.Name
                    </span>
                    <a href="#@type.Id" class="ml-auto font-mono text-xs text-base-400 dark:text-base-500 hover:text-tertiary-one-900 dark:hover:text-tertiary-one-400" aria-label="Anchor">#</a>
                </div>

                @if (!string.IsNullOrEmpty(type.SummaryHtml))
                {
                    <p class="text-base-600 dark:text-base-400 text-[15px] leading-relaxed max-w-3xl">
                        @((MarkupString)type.SummaryHtml)
                    </p>
                }

                @foreach (var section in type.Sections)
                {
                    <div class="pt-2">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="text-sm font-medium text-base-900 dark:text-primary-50">@section.Heading</span>
                            <span class="font-mono text-[11px] text-base-500 dark:text-base-400 px-1.5 py-0.5 bg-base-100 dark:bg-base-800 rounded">@section.Rows.Count</span>
                            <span class="flex-1 h-px bg-gradient-to-r from-base-200 dark:from-base-800 to-transparent"></span>
                        </div>
                        <table class="w-full font-mono text-[13px] border-collapse">
                            <tbody>
                                @foreach (var row in section.Rows)
                                {
                                    <tr class="border-b border-base-100 dark:border-base-800/60 last:border-0 hover:bg-base-50/50 dark:hover:bg-base-900/40">
                                        <td class="py-2 pr-4 align-top">
                                            @((MarkupString)row.SignatureHtml)
                                        </td>
                                        <td class="py-2 align-top font-sans text-[13px] text-base-600 dark:text-base-400 leading-snug">
                                            @((MarkupString)row.SummaryHtml)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        }
    </div>
</div>

@code {
    // Curated, ordered slice of the public surface — the types a consumer configures
    // or extends. GetTypesAsync would return the entire assembly; we pin these by UID.
    private static readonly string[] WantedUids =
    [
        "T:MonorailCss.CssFramework",
        "T:MonorailCss.CssFrameworkSettings",
        "T:MonorailCss.ColorEmissionMode",
        "T:MonorailCss.CustomVariantDefinition",
    ];

    private List<TypeSection> _types = [];
    private List<Breadcrumbs.BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new() { Title = "Home", Url = "/" },
            new() { Title = "Reference", Url = string.Empty },
            new() { Title = "API Reference", IsCurrent = true },
        ];

        var sections = new List<TypeSection>();
        foreach (var uid in WantedUids)
        {
            var detail = await Api.GetTypeAsync(uid);
            if (detail is null)
            {
                continue;
            }

            var summary = detail.Summary;
            var members = (await Api.GetMembersAsync(uid, MemberKind.All, AccessFilter.Public, MemberOrder.Declaration)).ToList();

            var memberSections = new List<MemberSection>();
            void Add(MemberKind kind, string heading)
            {
                var rows = members
                    .Where(m => m.Kind == kind)
                    .Select(m => new MemberRow(m.SignatureHtml ?? string.Empty, RenderSummary(m.Xmldoc)))
                    .ToList();
                if (rows.Count > 0)
                {
                    memberSections.Add(new MemberSection(heading, rows));
                }
            }

            Add(MemberKind.Constructors, "Constructors");
            Add(MemberKind.Properties, "Properties");
            Add(MemberKind.Methods, "Methods");
            Add(MemberKind.Fields, summary.Kind == ApiTypeKind.Enum ? "Values" : "Fields");
            Add(MemberKind.Events, "Events");

            sections.Add(new TypeSection(
                Id: summary.Name,
                Name: summary.Name,
                Namespace: summary.Namespace,
                KindLabel: KindLabel(summary.Kind),
                KindCode: KindCode(summary.Kind),
                SummaryHtml: RenderSummary(detail.Xmldoc),
                MemberCount: members.Count,
                Sections: memberSections));
        }

        _types = sections;
    }

    private string RenderSummary(ParsedXmlDoc? doc) =>
        doc is { HasSummary: true } ? DocRenderer.RenderInlineHtml(doc.Summary) : string.Empty;

    private static string KindLabel(ApiTypeKind kind) => kind switch
    {
        ApiTypeKind.Class => "Class",
        ApiTypeKind.Record => "Record",
        ApiTypeKind.Struct => "Struct",
        ApiTypeKind.Interface => "Interface",
        ApiTypeKind.Enum => "Enum",
        ApiTypeKind.Delegate => "Delegate",
        _ => kind.ToString(),
    };

    // Coloring buckets, mirrored from the original page: class/record share one accent,
    // interfaces another, enums another, everything else falls through to neutral.
    private static string KindCode(ApiTypeKind kind) => kind switch
    {
        ApiTypeKind.Class or ApiTypeKind.Record => "C",
        ApiTypeKind.Interface => "I",
        ApiTypeKind.Enum => "E",
        _ => "S",
    };

    private static string KindClasses(string kind) => kind switch
    {
        "C" => "text-accent-700 dark:text-accent-400 border-accent-200 dark:border-accent-800/60 bg-accent-50/50 dark:bg-accent-900/20",
        "I" => "text-tertiary-one-700 dark:text-tertiary-one-400 border-tertiary-one-200 dark:border-tertiary-one-800/60 bg-tertiary-one-50/50 dark:bg-tertiary-one-900/20",
        "E" => "text-primary-700 dark:text-primary-400 border-primary-200 dark:border-primary-800/60 bg-primary-50/50 dark:bg-primary-900/20",
        _ => "text-base-700 dark:text-base-300 border-base-200 dark:border-base-700 bg-base-50 dark:bg-base-900",
    };

    private record MemberRow(string SignatureHtml, string SummaryHtml);

    private record MemberSection(string Heading, IReadOnlyList<MemberRow> Rows);

    private record TypeSection(
        string Id,
        string Name,
        string Namespace,
        string KindLabel,
        string KindCode,
        string SummaryHtml,
        int MemberCount,
        IReadOnlyList<MemberSection> Sections);
}
