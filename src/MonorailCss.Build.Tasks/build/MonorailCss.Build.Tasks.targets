<Project>
  <!-- MonorailCss Build Task Definition -->
  <UsingTask TaskName="MonorailCss.Build.Tasks.ProcessCssTask"
             AssemblyFile="$(MSBuildThisFileDirectory)..\bin\$(Configuration)\net9.0\MonorailCss.Build.Tasks.dll"
             Condition="'$(MonorailCssDevelopment)' == 'true'" />
  <UsingTask TaskName="MonorailCss.Build.Tasks.ProcessCssTask"
             AssemblyFile="$(MSBuildThisFileDirectory)..\tasks\net9.0\MonorailCss.Build.Tasks.dll"
             Condition="'$(MonorailCssDevelopment)' != 'true'" />

  <!-- MSBuild item types this targets file introduces:
         <MonorailCss Include="path/to/app.css" />              — input CSS files to process
         <MonorailCssExcludeAssembly Include="AssemblyName" />  — assemblies to skip during reference scan
       The latter mirrors MonorailDiscoveryOptions.ExcludeAssemblies on the runtime side; useful
       for libraries (icon packs, MonorailCss itself) whose IL strings would inflate output. -->
  <ItemGroup>
    <AvailableItemName Include="MonorailCss" />
  </ItemGroup>

  <!-- IDE hint: MonorailCssExcludeAssembly values are bare assembly names ("MonorailCss",
       "BadIdeas.Icons.FontAwesome"), not file paths. Rider/VS would otherwise render them as
       missing-file tree nodes in Solution Explorer. <Visible>false</Visible> is the standard
       metadata both IDEs honour to suppress that. -->
  <ItemDefinitionGroup>
    <MonorailCssExcludeAssembly>
      <Visible>false</Visible>
    </MonorailCssExcludeAssembly>
  </ItemDefinitionGroup>

  <PropertyGroup>
    <!-- Hook into dotnet watch's file-set collection. _CollectWatchItems in the SDK depends on
         every target name listed in $(CustomCollectWatchItems); appending our target here lets
         us contribute @(MonorailCss) inputs without overriding what Razor SDK already added.
         Property evaluation: this targets file imports BEFORE Sdk.targets in SDK-style
         projects, so $(IntermediateOutputPath) isn't set here yet — properties that need it
         (e.g. the cache directory) live inside the target body instead. -->
    <CustomCollectWatchItems>$(CustomCollectWatchItems);_MonorailCssCollectWatchItems</CustomCollectWatchItems>
  </PropertyGroup>

  <!-- Process each MonorailCss file.
       BeforeTargets="CoreCompile" runs after ResolveAssemblyReferences populates
       @(ReferencePath) with absolute paths to every project + package + framework reference
       MSBuild resolved — exactly the set the runtime would load via AppDomain.GetAssemblies()
       after force-load. Earlier hooks (BeforeBuild) fire before resolution and miss it.
       DependsOnTargets keeps the dependency explicit and forces in-tree task DLL builds
       (when MonorailCss.Build.Tasks is consumed via ProjectReference) before the UsingTask
       resolves. -->
  <Target Name="ProcessMonorailCss"
          BeforeTargets="CoreCompile"
          DependsOnTargets="ResolveProjectReferences;ResolveAssemblyReferences"
          Condition="'$(MonorailCssEnabled)' == 'true' and '@(MonorailCss)' != ''"
          Inputs="@(MonorailCss);@(Content);@(Compile);@(EmbeddedResource);@(ReferencePath)"
          Outputs="@(MonorailCss->'%(OutputFile)')">

    <ItemGroup>
      <MonorailCss>
        <OutputFile Condition="'%(OutputFile)' == ''">$(MSBuildProjectDirectory)\wwwroot\css\%(Filename).css</OutputFile>
      </MonorailCss>
    </ItemGroup>

    <!-- Persistent scan cache directory. Defaulted inside the target so it can reference
         $(IntermediateOutputPath), which Sdk.targets sets after our top-level Import. -->
    <PropertyGroup>
      <MonorailCssCacheDirectory Condition="'$(MonorailCssCacheDirectory)' == ''">$(IntermediateOutputPath)MonorailCss\</MonorailCssCacheDirectory>
    </PropertyGroup>

    <MakeDir Directories="$(MonorailCssCacheDirectory)" />

    <ProcessCssTask
      InputFile="%(MonorailCss.Identity)"
      OutputFile="%(MonorailCss.OutputFile)"
      ReferencePaths="@(ReferencePath)"
      ExcludeAssemblies="@(MonorailCssExcludeAssembly)"
      Configuration="$(Configuration)"
      TargetFramework="$(TargetFramework)"
      RuntimeIdentifier="$(RuntimeIdentifier)"
      CacheDirectory="$(MonorailCssCacheDirectory)">
      <Output TaskParameter="FileWrites" ItemName="FileWrites" />
    </ProcessCssTask>

  </Target>

  <!-- dotnet watch integration. The SDK's _CollectWatchItems target reads target names from
       the $(CustomCollectWatchItems) property and runs each as a dependency, mirroring how
       Razor SDK contributes .razor/.cshtml files via _RazorSdkCustomCollectWatchItems. We
       append our @(MonorailCss) input CSS files so editing app.css triggers dotnet watch's
       rebuild path instead of falling through to static-asset hot-push (which would skip
       ProcessCssTask entirely). .razor and .cs are already covered by Razor SDK / @(Compile). -->
  <Target Name="_MonorailCssCollectWatchItems"
          Condition="'$(MonorailCssEnabled)' == 'true' and '@(MonorailCss)' != ''">
    <ItemGroup>
      <Watch Include="@(MonorailCss)" />
    </ItemGroup>
  </Target>

  <!-- Clean target to remove generated files -->
  <Target Name="CleanMonorailCss"
          BeforeTargets="Clean"
          Condition="'$(MonorailCssEnabled)' == 'true'">
    <Delete Files="@(MonorailCss->'%(OutputFile)')" />
    <RemoveDir Directories="$(MonorailCssCacheDirectory)" Condition="Exists('$(MonorailCssCacheDirectory)')" />
  </Target>
</Project>
